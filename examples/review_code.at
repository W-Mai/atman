flow review_code(file: path) -> Review {
    contract {
        scope {
            read: [project_root]
            write: []
        }
        interjection {
            accept: [L1, L4]
        }
    }

    gather = fanout [
        fs.read(file),
        fetch_rule("code-review"),
        fetch_confessions(tag: "code-review"),
    ] collect: all

    primary = llm {
        model: "claude-opus-4.7"
        prompt: @"prompts/code-review.md"
        input: gather
        schema: Review
        cache: true
        retry: 2
    }

    verify = llm {
        model: "gpt-4o-mini"
        prompt: @"prompts/verify.md"
        input: primary
        schema: { valid: bool, issues: [string] }
    }

    when verify.valid == false {
        primary = llm {
            model: "claude-opus-4.7"
            prompt: @"prompts/code-review.md"
            input: gather
            schema: Review
            cache: true
            retry: 2
        }
    }

    when primary.severity == "critical" {
        user_confirm("发现严重问题,是否继续?")
    }

    return primary
}
