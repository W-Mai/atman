flow review_code(file: path) -> Review {
    contract {
        scope {
            read: [project_root]
            write: []
        }
        interjection {
            accept: [L1, L4]
        }
    }

    gather = fanout [
        fs.read(file),
        fetch_rule("code-review"),
        fetch_confessions(tag: "code-review"),
    ] collect: all

    primary = llm {
        model: "claude-opus-4.7"
        messages: [system_msg(@"prompts/code-review.md"), user_msg("Review the code and gathered context.")]
        input: gather
        schema: Review
        cache: true
        retry: 2
    }

    verify = llm {
        model: "gpt-4o-mini"
        messages: [system_msg(@"prompts/verify.md"), user_msg("Verify the review above.")]
        input: primary
        schema: { valid: bool, issues: [string] }
    }

    when verify.valid == false {
        primary = llm {
            model: "claude-opus-4.7"
            messages: [system_msg(@"prompts/code-review.md"), user_msg("Try again with more care.")]
            input: gather
            schema: Review
            cache: true
            retry: 2
        }
    }

    when primary.severity == "critical" {
        user_confirm("发现严重问题,是否继续?")
    }

    audit = preview.push(
        topic: "code-reviews",
        title: "review " + file,
        content: "```json\n" + to_json_string(primary) + "\n```",
    )

    return primary
}
