flow edit_and_verify(file: path, instruction: string) -> EditResult {
    contract {
        scope {
            read: [project_root]
            write: [project_root]
        }
        capabilities {
            shell: true
        }
    }

    original = fs.read(file)

    edited = llm {
        model: "claude-opus-4.7"
        messages: [system_msg(@"prompts/edit.md"), user_msg("Apply the instruction to the file.")]
        input: { file: file, original: original, instruction: instruction }
        schema: { new_content: string, rationale: string }
    }

    ok = user_confirm("Apply edit to " + shell_quote(instruction) + "?")

    when ok == false {
        return { status: "cancelled" }
    }

    fs.write(file, edited.new_content)

    check = bash.exec("cargo check")

    when check.exit != 0 {
        fs.write(file, original)
        audit_fail = preview.push(
            topic: "edit-and-verify",
            title: "reverted: " + file,
            content: "**reverted after cargo check failed.**\n\n```\n" + check.stderr + "\n```",
        )
        return { status: "reverted", stderr: check.stderr }
    }

    audit = preview.push(
        topic: "edit-and-verify",
        title: "applied: " + file,
        content: "**rationale:** " + edited.rationale + "\n\n```diff\n" + edited.new_content + "\n```",
    )

    return { status: "applied", rationale: edited.rationale }
}
