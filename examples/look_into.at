flow look_into(question: string) -> Report {
    contract {
        scope {
            read: [project_root]
        }
    }

    findings = fanout [
        subflow(explore_module, question, "src/"),
        subflow(explore_module, question, "tests/"),
    ] collect: all

    summary = llm {
        model: "smart"
        messages: [system_msg(@"prompts/synthesize.md"), user_msg("Synthesize findings for the question.")]
        input: { question: question, findings: findings }
        schema: Report
        cache: true
    }

    audit = preview.push(
        topic: "look-into",
        title: "look-into: " + question,
        content: "```json\n" + to_json_string(summary) + "\n```",
    )

    return summary
}

flow explore_module(question: string, dir: string) -> Finding {
    return llm {
        model: "cheap"
        messages: [user_msg("Focus on: " + question + " in " + dir)]
        schema: Finding
    }
}
