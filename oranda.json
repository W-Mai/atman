{
  "project": {
    "name": "atman",
    "description": "A flow-driven AI coding agent runtime. Write agent workflows in the .at DSL — Turing-complete, inspectable, deterministic. The LLM is one node; atman orchestrates the rest.",
    "repository": "https://github.com/W-Mai/atman",
    "homepage": "https://atman.run",
    "license": "MIT OR Apache-2.0",
    "readme_path": "LANDING.md"
  },
  "marketing": {
    "social": {
      "image": "static/ATMAN-LOGO.png",
      "image_alt": "atman — flow-driven AI coding agent runtime. Turing-complete .at DSL, deterministic orchestration, the LLM is one node."
    }
  },
  "components": {
    "artifacts": {
      "cargo_dist": true,
      "package_managers": {
        "preferred": {
          "cargo": "cargo install atman-cli --locked --profile=dist",
          "crates.io": "cargo install atman-cli --locked",
          "homebrew": "brew install W-Mai/cellar/atman-cli"
        },
        "additional": {
          "binstall": "cargo binstall atman-cli",
          "shell": "curl -fsSL https://atman.run/install.sh | sh",
          "powershell": "irm https://atman.run/install.ps1 | iex"
        }
      }
    },
    "changelog": false
  },
  "styles": {
    "theme": "dark",
    "additional_css": ["static/atman-landing.css"],
    "favicon": "static/ATMAN-LOGO.png"
  }
}
